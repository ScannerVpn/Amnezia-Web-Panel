# ─────────────────────────────────────────────────────────────────────────────
# Amnezia Web Panel — Environment configuration template
# Copy to `.env` and customize before running `docker compose up -d --build`.
# ─────────────────────────────────────────────────────────────────────────────

# Admin credentials (REQUIRED on first run)
# If ADMIN_PASSWORD is not set, the panel will auto-generate one and log it.
ADMIN_USERNAME=admin
ADMIN_PASSWORD=changeme-to-strong-password

# Flask/FastAPI session secret — leave empty to auto-generate and persist to disk
# (recommended). Set explicitly only if you need stable sessions across rebuilds.
SECRET_KEY=

# Panel HTTP port
PANEL_PORT=54325

# Where panel state (data.json, encryption key, known_hosts) is stored
DATA_DIR=/app/data

# ── Security options ─────────────────────────────────────────────────────────
# Set to "1" (default) for strict SSH host key verification.
# Set to "0" to fall back to AutoAddPolicy (insecure — for first-run only).
SSH_STRICT_HOST_KEY=1
